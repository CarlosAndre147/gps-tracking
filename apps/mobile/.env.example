# Base URL da API (sem barra final).
# Emulador Android: use http://10.0.2.2:3000 para apontar ao host da máquina.
# Android físico via USB: rode `pnpm --filter @gps-tracker/mobile android:usb` e use http://localhost:3000.
# Dispositivo físico na mesma rede: use http://<IP-da-sua-LAN>:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
