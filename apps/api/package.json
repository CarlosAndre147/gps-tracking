{
  "name": "@gps-tracker/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "lint": "echo \"lint - add eslint in Day 2\"",
    "typecheck": "tsc --noEmit",
    "seed": "bun run drizzle/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run drizzle/migrate-runner.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run drizzle/seed.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "@elysiajs/bearer": "^1.2.0",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/jwt": "^1.2.0",
    "@elysiajs/swagger": "^1.3.1",
    "@elysia/server-timing": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.2",
    "drizzle-typebox": "^0.3.3",
    "exact-mirror": "0.2.7",
    "elysia": "^1.2.25",
    "elysia-rate-limit": "^4.1.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.11.10",
    "bun-types": "^1.2.0",
    "drizzle-kit": "^0.31.1",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.3"
  }
}
