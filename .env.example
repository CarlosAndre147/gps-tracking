# Database
DATABASE_URL="postgresql://gps:gps@localhost:5432/gps_tracker?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (use long random strings in production)
JWT_SECRET="change-me-access-token-secret-min-32-chars"
REFRESH_SECRET="change-me-refresh-token-secret-min-32-chars"

# CORS — comma-separated origins (scheme + host + port) allowed by the browser.
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:8081"

# Seed (System Admin — created only via seed)
SEED_ADMIN_EMAIL="admin@gps-tracker.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# API
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"

# Scalar API docs (/docs) — required when NODE_ENV is not production; ignored in production
SCALAR_USER="dev"
SCALAR_PASSWORD="change_me"
